<style>
  footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3rem 0 2rem;
    margin-top: 6rem;
    font-size: 0.9rem;
    color: #999;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2rem;
    max-width: 100%;
  }

  .footer-section h3 {
    color: #fff;
    font-size: 1rem;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .footer-section p {
    margin: 0.5rem 0;
    line-height: 1.6;
  }

  .footer-section a {
    color: #4ade80;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-section a:hover {
    color: #22c55e;
  }

  .socials {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .socials li {
    margin-bottom: 0.5rem;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    color: #666;
    font-size: 0.85rem;
  }

  @media screen and (max-width: 50em) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>