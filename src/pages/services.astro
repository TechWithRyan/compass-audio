---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const title = "Our Services";
const description = "Professional music production services at Compass Audio";

const services = [
  {
    title: "Full Production",
    description: "Complete music production from concept to release",
    price: "2,500 kr",
    details: ["Beats & arrangement", "Vocal recording", "Mix & Master", "Release support"]
  },
  {
    title: "Vocal Recording",
    description: "Professional vocal recording sessions",
    price: "750 kr",
    details: ["Studio time", "Professional recording", "Mixing included"]
  },
  {
    title: "Mix & Master",
    description: "Professional mixing and mastering",
    price: "1,000 kr",
    details: ["Mixing", "Mastering", "Quality assurance"]
  },
  {
    title: "Photo Session",
    description: "Artist material photo sessions",
    price: "500 kr/h",
    details: ["Professional photography", "Image selection", "Creative direction"]
  }
];
---

<BaseLayout title={title}>
  <div class="services-container">
    <h1>Our Services</h1>
    <p class="intro">At Compass Audio, we're committed to long-term collaboration and community. We don't just produce music – we build relationships and help artists grow.</p>
    
    <div class="services-grid">
      {services.map((service) => (
        <div class="service-card">
          <h3>{service.title}</h3>
          <p class="service-description">{service.description}</p>
          <p class="service-price">{service.price}</p>
          <ul class="service-details">
            {service.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="cta-section">
      <h2>Ready to Create?</h2>
      <p>Let's build something amazing together. Book a session with us on Calendly.</p>
      <a href="https://calendly.com/" class="cta-button" target="_blank">Book Now on Calendly</a>
    </div>
  </div>
</BaseLayout>

<style>
  .services-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 20px;
    color: #fff;
  }

  .intro {
    font-size: 1.1rem;
    color: #ccc;
    margin-bottom: 60px;
    max-width: 700px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    margin-bottom: 80px;
  }

  .service-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 30px;
    border-radius: 10px;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
  }

  .service-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-5px);
  }

  .service-card h3 {
    font-size: 1.5rem;
    margin-bottom: 10px;
    color: #fff;
  }

  .service-description {
    color: #aaa;
    margin-bottom: 15px;
    font-size: 0.95rem;
  }

  .service-price {
    font-size: 1.8rem;
    font-weight: bold;
    color: #4ade80;
    margin-bottom: 20px;
  }

  .service-details {
    list-style: none;
    padding: 0;
  }

  .service-details li {
    color: #999;
    padding: 5px 0;
    font-size: 0.9rem;
  }

  .service-details li:before {
    content: "✓ ";
    color: #4ade80;
    font-weight: bold;
    margin-right: 8px;
  }

  .cta-section {
    text-align: center;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.3);
    padding: 60px 40px;
    border-radius: 10px;
  }

  .cta-section h2 {
    font-size: 2rem;
    margin-bottom: 15px;
    color: #fff;
  }

  .cta-section p {
    color: #ccc;
    margin-bottom: 25px;
  }

  .cta-button {
    display: inline-block;
    background: #4ade80;
    color: #000;
    padding: 15px 40px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background: #22c55e;
    transform: scale(1.05);
  }
</style>