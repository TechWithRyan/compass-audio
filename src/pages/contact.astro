---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact - Compass Audio">
  <div class="contact-container">
    <h1>Get In Touch</h1>
    <p class="intro">Ready to create something amazing? Let's collaborate.</p>

    <div class="contact-content">
      <div class="contact-info">
        <h2>Contact Information</h2>
        <p><strong>Email:</strong> ryan.cornelio@gmail.com</p>
        <p><strong>Location:</strong> Kungälv, Sweden</p>
        <p><strong>Studio:</strong> Compass Audio</p>
      </div>

      <div class="booking-section">
        <h2>Book a Session</h2>
        <p>Schedule your studio session directly through Calendly. Choose the service and time that works best for you.</p>
        <a href="https://calendly.com/" target="_blank" class="calendly-button">Open Calendly to Book</a>
      </div>
    </div>

    <div class="message">
      <p>We believe in long-term collaboration and community. Let's build something together.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 10px;
    color: #fff;
  }

  .intro {
    font-size: 1.2rem;
    color: #aaa;
    margin-bottom: 60px;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    margin-bottom: 60px;
  }

  .contact-info h2,
  .booking-section h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 20px;
  }

  .contact-info p {
    color: #aaa;
    margin-bottom: 15px;
    line-height: 1.6;
  }

  .booking-section p {
    color: #aaa;
    margin-bottom: 25px;
  }

  .calendly-button {
    display: inline-block;
    background: #4ade80;
    color: #000;
    padding: 15px 30px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .calendly-button:hover {
    background: #22c55e;
    transform: scale(1.05);
  }

  .message {
    text-align: center;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.3);
    padding: 40px;
    border-radius: 10px;
  }

  .message p {
    color: #ccc;
    font-size: 1.1rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .contact-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    h1 {
      font-size: 2rem;
    }
  }
</style>

